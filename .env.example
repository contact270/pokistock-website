# ── Instagram Graph API ───────────────────────────────────────────────────────
# Step-by-step to get these values:
#
#   1. Go to developers.facebook.com → My Apps → Create App
#   2. Choose "Business" type → add "Instagram Graph API" product
#   3. Connect your Instagram Business / Creator account via Facebook Page
#   4. Under Instagram Graph API → Generate Token → copy the long-lived token
#   5. To find your User ID: call
#      https://graph.facebook.com/v20.0/me?fields=id&access_token=YOUR_TOKEN
#
INSTAGRAM_ACCESS_TOKEN=your_long_lived_page_access_token_here
INSTAGRAM_USER_ID=your_numeric_instagram_user_id_here

# ── Firebase / Google Analytics (module coming next) ─────────────────────────
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
# GA4_PROPERTY_ID=your_ga4_property_id

# ── Microsoft Clarity (module coming next) ────────────────────────────────────
# CLARITY_PROJECT_ID=your_project_id
# CLARITY_API_TOKEN=your_api_token
